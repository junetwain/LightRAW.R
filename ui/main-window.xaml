<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightRAW.R"
        Width="1400"
        Height="900"
        MinWidth="1000"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#FF181818"
        Foreground="#FFF5F5F5">
  <Window.Resources>
    <Style x:Key="EdgeLikeScrollBarLineButtonStyle" TargetType="RepeatButton">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="IsTabStop" Value="False" />
      <Setter Property="Visibility" Value="Collapsed" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border Background="Transparent" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EdgeLikeVerticalScrollBarStyle" TargetType="ScrollBar">
      <Setter Property="Width" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent" Width="{TemplateBinding Width}">
              <Track x:Name="PART_Track" IsDirectionReversed="True" Focusable="False">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource EdgeLikeScrollBarLineButtonStyle}" />
                </Track.DecreaseRepeatButton>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource EdgeLikeScrollBarLineButtonStyle}" />
                </Track.IncreaseRepeatButton>
                <Track.Thumb>
                  <Thumb x:Name="Thumb" Margin="2,0,2,0">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBody"
                                CornerRadius="4"
                                Background="#B2393939"
                                MinHeight="24" />
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#CC4A4A4A" />
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#FF5A5A5A" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
              </Track>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="1" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0" />
              </Trigger>
              <Trigger Property="Maximum" Value="0">
                <Setter Property="Opacity" Value="0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="Opacity" Value="0" />
    </Style>

    <Style x:Key="EdgeLikeListScrollViewerStyle" TargetType="ScrollViewer">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollViewer">
            <Grid Background="{TemplateBinding Background}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
              </Grid.ColumnDefinitions>
              <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                      Grid.Column="0"
                                      Margin="0"
                                      CanContentScroll="{TemplateBinding CanContentScroll}" />
              <ScrollBar x:Name="PART_VerticalScrollBar"
                         Grid.Column="1"
                         Width="12"
                         Margin="4,4,0,4"
                         Maximum="{TemplateBinding ScrollableHeight}"
                         ViewportSize="{TemplateBinding ViewportHeight}"
                         Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                         Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                         SmallChange="1"
                         LargeChange="12"
                         Style="{StaticResource EdgeLikeVerticalScrollBarStyle}" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="Visibility" Value="Collapsed">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EdgeLikeFileListBoxStyle" TargetType="ListBox">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ScrollViewer"
                            Focusable="False"
                            Background="Transparent"
                            Style="{StaticResource EdgeLikeListScrollViewerStyle}"
                            CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                            HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                            VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
              </ScrollViewer>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="EdgeLikeInfoScrollViewerStyle" TargetType="ScrollViewer">
      <Setter Property="CanContentScroll" Value="False" />
      <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="PanningMode" Value="VerticalOnly" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollViewer">
            <Grid Background="{TemplateBinding Background}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
              </Grid.ColumnDefinitions>
              <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                      Grid.Column="0"
                                      Margin="0"
                                      CanContentScroll="{TemplateBinding CanContentScroll}" />
              <ScrollBar x:Name="PART_VerticalScrollBar"
                         Grid.Column="1"
                         Width="12"
                         Margin="4,4,0,4"
                         Maximum="{TemplateBinding ScrollableHeight}"
                         ViewportSize="{TemplateBinding ViewportHeight}"
                         Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                         Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                         SmallChange="1"
                         LargeChange="12"
                         Style="{StaticResource EdgeLikeVerticalScrollBarStyle}" />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="IsMouseOver" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="1" />
              </Trigger>
              <Trigger SourceName="PART_VerticalScrollBar" Property="Visibility" Value="Collapsed">
                <Setter TargetName="PART_VerticalScrollBar" Property="Opacity" Value="0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ToolbarToggleCheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#FFF5F5F5" />
      <Setter Property="Background" Value="#AA111111" />
      <Setter Property="BorderBrush" Value="#55FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <StackPanel Orientation="Horizontal"
                          VerticalAlignment="Center">
                <Grid Width="14"
                      Height="14"
                      Margin="0,0,6,0">
                  <Border x:Name="CheckMarkBox"
                          Background="#FF111111"
                          BorderBrush="#88FFFFFF"
                          BorderThickness="1"
                          CornerRadius="2" />
                  <Path x:Name="CheckMark"
                        Data="M 2 7 L 5.5 10.5 L 12 3.5"
                        Stroke="White"
                        StrokeThickness="2"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        Visibility="Collapsed" />
                </Grid>
                <ContentPresenter VerticalAlignment="Center" />
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckMarkBox" Property="Background" Value="#FF2B5D8A" />
                <Setter TargetName="CheckMarkBox" Property="BorderBrush" Value="#FF7FC7FF" />
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#99FFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AndroidSwitchCheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="#FFF5F5F5" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <Border x:Name="SwitchTrack"
                      Width="44"
                      Height="24"
                      CornerRadius="12"
                      Background="#FF4A4A4A"
                      BorderBrush="#FF7A7A7A"
                      BorderThickness="1">
                <Grid>
                  <Ellipse x:Name="SwitchThumb"
                           Width="18"
                           Height="18"
                           Fill="#FFF5F5F5"
                           HorizontalAlignment="Left"
                           Margin="3,0,0,0"
                           VerticalAlignment="Center" />
                </Grid>
              </Border>
              <TextBlock Text="{TemplateBinding Content}"
                         Margin="8,0,0,0"
                         Width="36"
                         VerticalAlignment="Center"
                         TextAlignment="Center"
                         Foreground="{TemplateBinding Foreground}"
                         FontWeight="SemiBold" />
            </StackPanel>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="SwitchTrack" Property="Background" Value="#FF2B5D8A" />
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#FF7FC7FF" />
                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,3,0" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#FFB8DFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RoundedButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="#FF444444" />
      <Setter Property="BorderBrush" Value="#FF444444" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.5" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="RoundedPreviewBackgroundSliderStyle" TargetType="Slider">
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Foreground" Value="#FF9FD2FF" />
      <Setter Property="Background" Value="#FF2A2A2A" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Slider">
            <Grid Margin="0,2,0,2">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <Border Grid.Row="0"
                      Height="10"
                      CornerRadius="5"
                      Background="#FF2E2E2E"
                      BorderBrush="#FF484848"
                      BorderThickness="1"
                      VerticalAlignment="Center" />

              <Track x:Name="PART_Track"
                     Grid.Row="0"
                     VerticalAlignment="Center"
                     Margin="0">
                <Track.DecreaseRepeatButton>
                  <RepeatButton Command="Slider.DecreaseLarge"
                                IsTabStop="False"
                                Focusable="False"
                                Background="Transparent"
                                BorderThickness="0">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                      <Thumb Width="22"
                        Height="12"
                         Background="#FFE7F4FF"
                         BorderBrush="#FF6FAAD6"
                         BorderThickness="1.5"
                         Cursor="Hand">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBody"
                          CornerRadius="5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" />
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#FFF2FAFF" />
                            <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#FF8BC4EF" />
                          </Trigger>
                          <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBody" Property="Background" Value="#FFFFFFFF" />
                            <Setter TargetName="ThumbBody" Property="BorderBrush" Value="#FF5A9FD1" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                  <RepeatButton Command="Slider.IncreaseLarge"
                                IsTabStop="False"
                                Focusable="False"
                                Background="Transparent"
                                BorderThickness="0">
                    <RepeatButton.Template>
                      <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                      </ControlTemplate>
                    </RepeatButton.Template>
                  </RepeatButton>
                </Track.IncreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#FF232323"
            CornerRadius="10"
            Padding="12"
            Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0">
          <TextBlock x:Name="QualityLabelText"
                     Text="Quality"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Foreground="#FFE0E0E0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFE0E0E0" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ElementName=PreviewSourceSwitch, Path=IsChecked}" Value="True">
                    <Setter Property="Foreground" Value="#FF8A8A8A" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
            <ComboBox x:Name="QualityPresetComboBox"
                      Width="96"
                      Height="30"
                VerticalAlignment="Center"
                Margin="0,0,6,0"
                SelectedIndex="1"
                      Background="#FF101010"
                      BorderBrush="#FF404040"
                Foreground="White"
                Padding="8,2"
                ToolTip="Preview quality preset">
              <ComboBox.Style>
                <Style TargetType="ComboBox">
                  <Setter Property="Foreground" Value="White" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ElementName=PreviewSourceSwitch, Path=IsChecked}" Value="True">
                      <Setter Property="Foreground" Value="#FF8A8A8A" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </ComboBox.Style>
              <ComboBox.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White" />
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White" />
                <Style TargetType="ToggleButton">
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Background}"
                                BorderBrush="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                          <Grid>
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="22" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Margin="8,2,4,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              TextElement.Foreground="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"
                                              Content="{TemplateBinding Content}" />
                                <Path Grid.Column="1"
                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                  Fill="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}"
                                  Width="8"
                                  Height="4"
                                  Stretch="Fill"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#FF5A5A5A" />
                          </Trigger>
                          <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ToggleBorder" Property="Background" Value="#FF141414" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
                <Style TargetType="ComboBoxItem">
                  <Setter Property="Background" Value="#FF101010" />
                  <Setter Property="Foreground" Value="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}, Path=Foreground}" />
                  <Setter Property="Height" Value="30" />
                  <Setter Property="Padding" Value="10,0,8,0" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}">
                          <ContentPresenter VerticalAlignment="Center"
                                            Margin="2,0,0,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF2B5D8A" />
                          </Trigger>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#FF2B5D8A" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ComboBox.Resources>
              <ComboBox.Template>
                <ControlTemplate TargetType="ComboBox">
                  <Grid>
                    <ToggleButton x:Name="ToggleButton"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                  ClickMode="Press"
                                  Content="{TemplateBinding SelectionBoxItem}" />
                    <Popup x:Name="Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           PopupAnimation="Slide">
                      <Border Margin="0,2,0,0"
                              Background="#FF101010"
                              BorderBrush="#FF404040"
                              BorderThickness="1"
                              CornerRadius="6"
                              MinWidth="{TemplateBinding ActualWidth}">
                        <ScrollViewer MaxHeight="220"
                                      SnapsToDevicePixels="True">
                          <StackPanel IsItemsHost="True"
                                      KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                      </Border>
                    </Popup>
                  </Grid>
                </ControlTemplate>
              </ComboBox.Template>
            <ComboBoxItem Content="Fast" />
            <ComboBoxItem Content="Balanced" />
            <ComboBoxItem Content="Sharp" />
            </ComboBox>

          <TextBlock Text="Preview"
                     VerticalAlignment="Center"
                     Margin="14,0,8,0"
                     Foreground="#FFE0E0E0" />
          <CheckBox x:Name="PreviewSourceSwitch"
                    VerticalAlignment="Center"
                    Style="{StaticResource AndroidSwitchCheckBoxStyle}"
                    ToolTip="Unchecked = JPG, Checked = RAW"
                    Content="JPG" />

            <StackPanel Orientation="Vertical"
              VerticalAlignment="Center"
              Margin="24,0,0,0">
              <TextBlock Text="Background Color"
                   Margin="0,0,0,4"
                   Foreground="#FFE0E0E0"
                   FontSize="12" />
              <StackPanel Orientation="Horizontal"
              VerticalAlignment="Center">
                <Slider x:Name="PreviewBackgroundSlider"
                        Width="185"
                  Minimum="0"
                  Maximum="255"
                  TickFrequency="5"
                  IsSnapToTickEnabled="False"
                  Value="35"
                  VerticalAlignment="Center"
                  ToolTip="Preview background grayscale"
                  Style="{StaticResource RoundedPreviewBackgroundSliderStyle}" />
                <TextBlock x:Name="PreviewBackgroundValueText"
               Margin="8,0,0,0"
               Width="34"
               VerticalAlignment="Center"
               Text="35"
               TextAlignment="Right"
               Foreground="#FFCFCFCF" />
              </StackPanel>
            </StackPanel>
        </StackPanel>

        <Button x:Name="BrowseButton"
                Grid.Column="1"
                Content="Select Folder"
          Style="{StaticResource RoundedButtonStyle}"
                Margin="0,0,8,0"
                Padding="14,3"
                Background="#FF2B5D8A"
                BorderBrush="#FF2B5D8A"
                Foreground="White" />

        <Button x:Name="RefreshButton"
                Grid.Column="2"
                Content="Refresh"
          Style="{StaticResource RoundedButtonStyle}"
                Margin="0,0,8,0"
                Padding="14,3"
                Background="#FF444444"
                BorderBrush="#FF444444"
                Foreground="White" />

        <Button x:Name="FailFolderButton"
                Grid.Column="3"
                Margin="0,0,8,0"
                Content="Set Reject Folder"
          Style="{StaticResource RoundedButtonStyle}"
                Padding="14,3"
                Background="#FF5A4A2D"
                BorderBrush="#FF5A4A2D"
                Foreground="White" />

        <Button x:Name="ToggleFailButton"
                Grid.Column="4"
                Margin="0,0,8,0"
                Content="Toggle Reject"
          Style="{StaticResource RoundedButtonStyle}"
                Padding="14,3"
                Background="#FF7A2E2E"
                BorderBrush="#FF7A2E2E"
                Foreground="White" />

        <Button x:Name="MoveFailedButton"
                Grid.Column="5"
                Margin="0,0,8,0"
                Content="Move Rejected"
          Style="{StaticResource RoundedButtonStyle}"
                Padding="14,3"
                Background="#FF7A2E2E"
                BorderBrush="#FF7A2E2E"
                Foreground="White" />

        <CheckBox x:Name="ShowInfoCheckBox"
                  Grid.Column="7"
                  VerticalAlignment="Center"
                  Style="{StaticResource ToolbarToggleCheckBoxStyle}"
                  IsChecked="True"
                  Content="Info" />

        <CheckBox x:Name="ShowOverlayCheckBox"
                  Grid.Column="6"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  Style="{StaticResource ToolbarToggleCheckBoxStyle}"
                  IsChecked="True"
                  Content="EXIF" />

        <TextBlock x:Name="AppStatusText"
                   Grid.Row="1"
                   Grid.Column="0"
                   Grid.ColumnSpan="3"
                   Margin="0,10,12,0"
                   FontSize="12"
                   Foreground="#FFB9D9FF"
                   Text="Status: Ready" />

        <TextBlock x:Name="FailFolderText"
                   Grid.Row="1"
                   Grid.Column="3"
                   Grid.ColumnSpan="4"
                   Margin="0,10,0,0"
                   FontSize="12"
                   Foreground="#FFCDAA7D"
                   TextWrapping="Wrap"
                   Text="Reject folder: not set" />
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="340" MinWidth="220" />
        <ColumnDefinition Width="8" />
        <ColumnDefinition Width="*" MinWidth="360" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="#FF232323"
              CornerRadius="10"
              Padding="10">
        <DockPanel>
          <TextBlock x:Name="CountText"
                     DockPanel.Dock="Top"
                     Margin="0,0,0,10"
                     FontSize="16"
                     FontWeight="SemiBold" />

          <ListBox x:Name="FileList"
                   Style="{StaticResource EdgeLikeFileListBoxStyle}"
                   Background="#FF101010"
                   BorderBrush="#FF303030"
                   Foreground="#FFF5F5F5"
                   FontFamily="Consolas"
                   FontSize="13"
                   Padding="6"
                   ScrollViewer.CanContentScroll="False"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="2" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <Border x:Name="SelectionBorder"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="10"
                              SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                          <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#FF4D8DFF" />
                          <Setter TargetName="SelectionBorder" Property="Background" Value="#252B5D8A" />
                        </Trigger>
                        <MultiTrigger>
                          <MultiTrigger.Conditions>
                            <Condition Property="IsSelected" Value="True" />
                            <Condition Property="Selector.IsSelectionActive" Value="False" />
                          </MultiTrigger.Conditions>
                          <Setter TargetName="SelectionBorder" Property="BorderBrush" Value="#AA4D8DFF" />
                          <Setter TargetName="SelectionBorder" Property="Background" Value="#1A2B5D8A" />
                        </MultiTrigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Padding="8"
                        x:Name="ListItemBorder"
                        CornerRadius="8"
                        Background="#FF181818"
                        BorderBrush="#FF353535"
                        BorderThickness="1">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110" />
                      <ColumnDefinition Width="12" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Height="74"
                            CornerRadius="6"
                            Background="#FF0D0D0D">
                      <Grid>
                        <Image Source="{Binding ThumbnailBitmap}"
                               Stretch="Uniform"
                               Margin="4" />
                        <TextBlock x:Name="ListThumbFallbackText"
                                   Text="No thumb"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Visibility="Collapsed"
                                   Foreground="#FF7A7A7A" />
                      </Grid>
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                      <TextBlock Text="{Binding PrimaryName}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap"
                                 MaxHeight="54" />
                      <TextBlock Text="{Binding Extensions}"
                                 Margin="0,6,0,0"
                                 FontSize="12"
                                 Foreground="#FFB8B8B8"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                </Border>
                <DataTemplate.Triggers>
                  <DataTrigger Binding="{Binding ThumbnailBitmap}" Value="{x:Null}">
                    <Setter TargetName="ListThumbFallbackText" Property="Visibility" Value="Visible" />
                  </DataTrigger>
                  <DataTrigger Binding="{Binding IsFailed}" Value="True">
                    <Setter TargetName="ListItemBorder" Property="Background" Value="#FF3C1616" />
                    <Setter TargetName="ListItemBorder" Property="BorderBrush" Value="#FFC85A5A" />
                  </DataTrigger>
                </DataTemplate.Triggers>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <GridSplitter Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    ShowsPreview="True"
                    ResizeBehavior="PreviousAndNext"
                    ResizeDirection="Columns" />

      <Border x:Name="PreviewBorder"
              Grid.Column="2"
              Background="#FF232323"
              CornerRadius="10"
              Padding="16">
        <Grid x:Name="PreviewHost"
              Background="Transparent"
              ClipToBounds="True">
            <Image x:Name="PreviewImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="LowQuality"
                   Visibility="Collapsed" />

            <Border x:Name="PreviewOverlayBorder"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="12"
                    Padding="10,8"
                    CornerRadius="8"
                    Background="#B3000000"
                    BorderBrush="#55FFFFFF"
                    BorderThickness="1"
                    Visibility="Collapsed">
              <TextBlock x:Name="PreviewOverlayText"
                         FontFamily="Consolas"
                         FontSize="14"
                         Foreground="#FFF5F5F5"
                         TextWrapping="Wrap" />
            </Border>

            <TextBlock x:Name="EmptyText"
                       Text="Select an item from the list."
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="24"
                       Foreground="#FFBDBDBD" />
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="InfoPanelBorder"
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="16"
            Background="#B3000000"
            BorderBrush="#55FFFFFF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12"
            MaxWidth="896"
            MinWidth="512"
            Visibility="Collapsed"
            Panel.ZIndex="20">
      <Grid MaxHeight="420">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
          <TextBlock Text="Histogram"
                     Margin="5,0,0,0"
                     FontFamily="Consolas"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#FFDDEEFF" />
          <Grid Margin="0,6,0,0"
                HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="214" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="214"
                    Height="86"
                    HorizontalAlignment="Left"
                    CornerRadius="6"
                    Background="#CC101010"
                    BorderBrush="#553A3A3A"
                    BorderThickness="1">
              <Grid Margin="6,4,6,4"
                    HorizontalAlignment="Left">
                <Canvas x:Name="HistogramCanvas"
                        Width="256"
                        Height="80"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        ClipToBounds="True"
                        SnapsToDevicePixels="True" />
                <TextBlock x:Name="HistogramStatusText"
                           Text="Histogram unavailable"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#FF909090"
                           FontSize="12"
                           FontFamily="Consolas" />
              </Grid>
            </Border>

            <TextBlock x:Name="HistogramSummaryText"
                       Grid.Column="2"
                       VerticalAlignment="Center"
                       FontFamily="Consolas"
                       FontSize="12"
                       LineHeight="18"
                       TextWrapping="Wrap"
                       Foreground="#FFC8D7E6"
                       Text="" />
          </Grid>
        </StackPanel>

        <ScrollViewer x:Name="InfoPopupScrollViewer"
                      Grid.Row="1"
                      Margin="0,8,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Style="{StaticResource EdgeLikeInfoScrollViewerStyle}">
          <StackPanel>
            <TextBlock x:Name="DetailsText"
                       Margin="0,4,0,0"
                       FontFamily="Consolas"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Foreground="#FFFFFFFF" />
            <TextBlock x:Name="SourceText"
                       Margin="0,8,0,0"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="#FFE0E0E0" />
            <TextBlock x:Name="ExifText"
                       Margin="0,10,0,0"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="#FFF5F5F5" />
            <TextBlock x:Name="AnalysisText"
                       Margin="0,10,0,0"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="#FFBFE3C0" />
            <TextBlock x:Name="InfoPropertiesText"
                       Margin="0,10,0,0"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="#FFD9D9D9" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</Window>
